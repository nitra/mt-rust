{
  "name": "@7n/mt-napi",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "description": "Build-обгортка napi-аддона mt (артефакти йдуть у платформні підпакети @7n/mt-*)",
  "license": "ISC",
  "scripts": {
    "build": "napi build --platform --release",
    "build:debug": "napi build --platform"
  },
  "devDependencies": {
    "@napi-rs/cli": "^3.7.4",
    "ajv": "^8.20.0"
  },
  "engines": {
    "bun": ">=1.3",
    "node": ">=24"
  },
  "napi": {
    "binaryName": "mt",
    "targets": [
      "aarch64-apple-darwin",
      "x86_64-unknown-linux-gnu"
    ]
  }
}
